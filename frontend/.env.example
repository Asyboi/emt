# Set to `true` to read from src/mock/mock_data.ts + src/mock/mock_pcr.ts
# (no backend needed). Set to `false` (or omit) to hit the live backend.
VITE_LOCAL_MODE=false

# Production-only: the absolute base URL of the FastAPI backend.
# Local dev uses Vite's /api proxy and ignores this.
VITE_API_URL=
