# ── AI APIs ──────────────────────────────────────────
ANTHROPIC_API_KEY=        # required — pipeline won't run without this
GOOGLE_API_KEY=           # required for video analysis (Gemini 2.5 Flash)
ELEVENLABS_API_KEY=       # required for audio transcription (Scribe v1)

# ── Frontend ─────────────────────────────────────────
# CORS allowlist — comma-separated for multiple origins.
FRONTEND_ORIGINS=http://localhost:5173

# ── Paths (leave blank to use defaults) ──────────────
CASES_DIR=../cases
PROTOCOLS_DIR=../protocols
FIXTURES_DIR=../fixtures

# ── Demo ─────────────────────────────────────────────
# When set, fresh cases (e.g. ones uploaded via the New Report UI) reuse this
# case's warmed upstream_cache.json for the PCR Auto-Draft so the demo's
# "drag in body-cam + audio + CAD" flow stays fast. Run
# `uv run python scripts/warm_cache.py case_01` once to populate the cache.
DEMO_UPSTREAM_CACHE_CASE_ID=case_01